{
  "extends": ["next/core-web-vitals", "prettier"],
  "plugins": ["tailwindcss"],
  "rules": {
    "tailwindcss/classnames-order": "warn",
    "tailwindcss/no-custom-classname": "off",
    "@next/next/no-html-link-for-pages": "off",
    "react/no-unescaped-entities": "off"
  },
  "settings": {
    "tailwindcss": {
      "callees": ["cn", "cva"]
    }
  }
}
